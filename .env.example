# ============================================================
#  Configurable Workflow System — Spring Boot
#  Copia este archivo como .env y completa los valores reales.
#  NUNCA subas .env al repositorio.
# ============================================================

# ── MongoDB ───────────────────────────────────────────────────────────────────
# URI de conexión obtenida desde el panel de MongoDB Atlas
# Formato: mongodb+srv://<usuario>:<contraseña>@<cluster-host>/<nombre-db>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@<cluster-host>/<db_name>?retryWrites=true&w=majority&appName=<app-name>

# ── JWT ───────────────────────────────────────────────────────────────────────
# Mínimo 256 bits (32 caracteres aleatorios). Genera con: openssl rand -base64 32
JWT_SECRET=<genera-una-clave-aleatoria-de-al-menos-32-caracteres>
JWT_EXPIRATION_MS=86400000

# ── Usuario ADMIN inicial ─────────────────────────────────────────────────────
# Se crea automáticamente al arrancar si no existe en la BD
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=<contraseña-segura-para-admin>

# ── FastAPI (backend IA) ──────────────────────────────────────────────────────
FASTAPI_BASE_URL=http://localhost:8001
FASTAPI_INTERNAL_KEY=<clave-interna-compartida-con-fastapi>

# ── WebSocket / CORS ──────────────────────────────────────────────────────────
WS_ALLOWED_ORIGINS=http://localhost:4200
CORS_ALLOWED_ORIGINS=http://localhost:4200

# ── AWS S3 (almacenamiento de archivos adjuntos) ──────────────────────────────
# Configura con credenciales de tu cuenta AWS (perfil CLI o variables explícitas)
STORAGE_BUCKET=<nombre-del-bucket-s3>
AWS_DEFAULT_REGION=us-east-1
# Si no usas perfil CLI, también puedes definir:
# AWS_ACCESS_KEY_ID=<tu-access-key>
# AWS_SECRET_ACCESS_KEY=<tu-secret-key>

# ── Servidor (opcional, default: 8080) ────────────────────────────────────────
SERVER_PORT=8080

# ── Datos demo ────────────────────────────────────────────────────────────────
# Contraseña para usuarios demo (officer@demo.com / cliente@demo.com)
# Solo se usa en el seed de datos demo — no exponer en producción
DEMO_PASSWORD=<contraseña-para-usuarios-demo>
