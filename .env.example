# ============================================================
#  Configurable Workflow System — Spring Boot
#  Copia este archivo como .env y completa los valores reales.
#  NUNCA subas .env al repositorio.
# ============================================================

# MongoDB Atlas
# Reemplaza <db_username> y <db_password> con tus credenciales reales
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@sw1-cluster.qlgrryc.mongodb.net/workflow_db?retryWrites=true&w=majority&appName=sw1-cluster

# JWT — mínimo 256 bits (32 caracteres aleatorios)
JWT_SECRET=<genera-una-clave-aleatoria-de-al-menos-32-caracteres>
JWT_EXPIRATION_MS=86400000

# FastAPI (backend IA)
FASTAPI_BASE_URL=http://localhost:8001
FASTAPI_INTERNAL_KEY=<clave-interna-compartida-con-fastapi>

# WebSocket / CORS
WS_ALLOWED_ORIGINS=http://localhost:4200

# Servidor (opcional, default: 8080)
SERVER_PORT=8080
